# marker-ui Configuration
# Copy to .env and customize

# Server
MARKER_HOST=127.0.0.1
MARKER_PORT=8000
MARKER_DEBUG=false

# Maximum upload size in MB
MARKER_MAX_UPLOAD_SIZE_MB=100

# Database URL (default: SQLite in data/ directory)
# MARKER_DATABASE_URL=sqlite+aiosqlite:///data/marker_ui.db

# LLM Service: none, openai, gemini, claude, ollama, azure, vertex
# MARKER_LLM_SERVICE=none
